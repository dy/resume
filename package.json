  "bugs": {
    "url": "https://github.com/dy/resume/issues"
  },
  "homepage": "https://github.com/dy/resume#readme",
  "dependencies": {
    "jsonresume-theme-actual": "^0.2.1",
    "jsonresume-theme-even": "^0.17.1",
    "jsonresume-theme-flat": "^0.3.7",
    "jsonresume-theme-joeytall": "^1.0.1",
    "jsonresume-theme-tachyons-clean": "^0.0.9",
    "resume-cli": "^3.1.2"
  }
}

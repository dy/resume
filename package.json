{
  "name": "cv",
  "version": "1.0.0",
  "description": "My cv",
  "main": "index.js",
  "scripts": {
    "build": "npm run build-html && npm run build-pdf",
    "build-html": "resume export index.html --format html --theme even",
    "build-pdf": "'/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --headless --no-pdf-header-footer --print-to-pdf=resume.pdf file://$PWD/index.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dy/resume.git"
  },
